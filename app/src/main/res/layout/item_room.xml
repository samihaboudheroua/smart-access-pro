<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:elevation="8dp"
    card_view:cardElevation="12dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title and Status Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Salon"
                android:textColor="#2D3E50"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Connecté"
                android:textColor="#00A676"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3">

            <!-- Card Button: Porte -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="8dp"
                card_view:cardElevation="6dp"
                card_view:cardCornerRadius="8dp"
                card_view:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:id="@+id/cardPorte"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_unselected"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/iconPorte"
                        android:layout_width="32dp"
                        android:layout_height="45dp"
                        android:paddingTop="8dp"
                        android:src="@drawable/ic_door"
                        android:tint="#444444" />

                    <TextView
                        android:id="@+id/textPorte"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Porte"
                        android:textColor="#444444"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Button: Fenêtre -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="8dp"
                card_view:cardElevation="6dp"
                card_view:cardCornerRadius="8dp"
                card_view:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:id="@+id/cardFenetre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_unselected"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/iconFenetre"
                        android:layout_width="32dp"
                        android:layout_height="45dp"
                        android:paddingTop="8dp"
                        android:src="@drawable/ic_window"
                        android:tint="#444444" />

                    <TextView
                        android:id="@+id/textFenetre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Fenêtre"
                        android:textColor="#444444"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Button: Volet -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="8dp"
                card_view:cardElevation="6dp"
                card_view:cardCornerRadius="8dp"
                card_view:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:id="@+id/cardVolet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_unselected"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/iconVolet"
                        android:layout_width="32dp"
                        android:layout_height="45dp"
                        android:paddingTop="8dp"
                        android:src="@drawable/ic_shutter"
                        android:tint="#444444" />

                    <TextView
                        android:id="@+id/textVolet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Volet"
                        android:textColor="#444444"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
