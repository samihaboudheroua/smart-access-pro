<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_teal"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white">

        <!-- Nested LinearLayout inside ScrollView -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp"
            >

            <!-- ✅ Header with bottom border -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                app:cardBackgroundColor="@color/light_teal"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                app:shapeAppearance="@style/BottomRoundedCardShape"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    app:strokeColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bottom_border"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <!-- Title and Subtitle -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.7"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/app_name"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/subtitle"
                                android:textColor="@color/white"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Icons -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.3"
                            android:gravity="end|center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/notificationButton"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_notification"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/white" />

                            <ImageView
                                android:id="@+id/profilButton"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_profile"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/white" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Bottom Border Line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#80FFFFFF" /> <!-- semi-transparent white -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature Cards Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="12dp"
                android:rowCount="2">

                <!-- Urgence Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/urgenceCard"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    card_view:cardBackgroundColor="@color/white"
                    card_view:cardCornerRadius="12dp"
                    card_view:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/urgence_ic"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="TODO"
                            android:src="@drawable/ic_emergency"
                            app:tint="@color/coral_red" />

                        <TextView
                            android:id="@+id/urgence_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/urgence"
                            android:textColor="@color/coral_red"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/urgence_description"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/urgence_description"
                            android:textColor="@color/coral_red"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>





                <androidx.cardview.widget.CardView
                    android:id="@+id/SecuriteCard"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    card_view:cardBackgroundColor="@color/white"
                    card_view:cardCornerRadius="12dp"
                    card_view:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/securite_ic"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/todo"
                            android:src="@drawable/securite_ic"
                            app:tint="@color/cyan_blue" />

                        <TextView
                            android:id="@+id/securite_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Sécurité"
                            android:textColor="@color/cyan_blue"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/securite_description"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Mode_sécurisé"
                            android:textColor="@color/cyan_blue"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>









                <androidx.cardview.widget.CardView
                    android:id="@+id/nuitCard"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    card_view:cardBackgroundColor="@color/white"
                    card_view:cardCornerRadius="12dp"
                    card_view:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/nuit_ic"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="TODO"
                            android:src="@drawable/ic_nuit"
                            app:tint="@color/dark_gray" />

                        <TextView
                            android:id="@+id/nuit_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Mode_Nuit"
                            android:textColor="@color/dark_gray"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/nuit_description"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Fermeture_auto"
                            android:textColor="@color/dark_gray"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>








                <androidx.cardview.widget.CardView
                    android:id="@+id/vacancesCard"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    card_view:cardBackgroundColor="@color/white"
                    card_view:cardCornerRadius="12dp"
                    card_view:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/vacances_ic"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="TODO"
                            android:src="@drawable/ic_vacances"
                            app:tint="@color/dark_gray" />

                        <TextView
                            android:id="@+id/vacances_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Vacances"
                            android:textColor="@color/dark_gray"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/vacances_description"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Simulation_présence"
                            android:textColor="@color/dark_gray"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <!-- Add more feature cards here -->
            </GridLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="@string/etat_du_systeme"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/deep_blue" />

            <!-- État du système Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                card_view:cardCornerRadius="16dp"
                card_view:cardElevation="8dp"
                android:backgroundTint="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:orientation="vertical"
                    android:padding="16dp">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/resume_general"
                        android:textColor="@color/dark_gray"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/ouvertures_count"
                            android:textColor="@color/coral_red" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/fermees_count"
                            android:textColor="@color/dark_gray" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/ouvertes_count"
                            android:textColor="@color/teal_green" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation always visible -->


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <include layout="@layout/bottom_nav" />

    </LinearLayout>


</LinearLayout>
